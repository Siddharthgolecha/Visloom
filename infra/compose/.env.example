# infra/compose/.env.example
#
# Placeholder values only — never a real secret (AGENTS.md
# privacy-by-default). Copy to infra/compose/.env and fill in real
# values for a local run. NOTE: infra/compose/.env is not yet in
# .gitignore — that's a slice-9 (dev-workflow) gap, not this slice's
# scope; do not commit a real .env in the meantime.

POSTGRES_USER=visloom
POSTGRES_PASSWORD=change-me
POSTGRES_DB=visloom

# Dev default is plain HTTP on :80 inside the container (mapped to
# host :8080 by compose.yml). Prod overlay sets this to a real
# domain, which switches Caddy's automatic HTTPS on.
SITE_ADDRESS=:80

OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
